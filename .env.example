# =============================================================================
# Portfolio Backend — Environment Variables Example
# Copy this file to .env and fill in secrets.
# =============================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
DATABASE_URL=postgres://portfolio:portfolio@localhost:5432/portfolio
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECT_RETRY_SECS=60

# Optional Redis URL (health probe only; app code does not connect yet — presence/gate not persisted)
REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------------------------
# Auth / Admin
# ----------------------------------------------------------------------------
JWT_SECRET=change_me_to_a_long_random_secret
REFRESH_TOKEN_SECRET=change_me_to_another_long_random_secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
# Prefer ADMIN_HASH_PASSWORD in production (generate via `cargo run --bin hash-password`)
ADMIN_HASH_PASSWORD=

# ----------------------------------------------------------------------------
# CORS
# Comma-separated browser origins. For local dev with production URL listed,
# also add http://localhost:3000 (and :3001/:3002 if Next picks another port).
# In ENVIRONMENT=development the backend also auto-merges localhost origins.
# ----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000

# ----------------------------------------------------------------------------
# Site metadata (RSS, emails)
# ----------------------------------------------------------------------------
SITE_URL=http://localhost:3000
SITE_TITLE="Dimas Saputra"
SITE_DESCRIPTION="Full-Stack Developer Portfolio"

# ----------------------------------------------------------------------------
# Email (Resend)
# ----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM=
CONTACT_EMAIL=

# ----------------------------------------------------------------------------
# Roadmap.sh proxy
# Backend logs in via POST https://roadmap.sh/api/v1-login and caches the JWT.
# ----------------------------------------------------------------------------
ROADMAP_EMAIL=
ROADMAP_PASSWORD=

# ----------------------------------------------------------------------------
# GitHub API proxy (#26)
# Personal access token — raises rate limits for /api/github/*
# ----------------------------------------------------------------------------
GH_TOKEN=

# ----------------------------------------------------------------------------
# Terminal gate (NATAS-style puzzles)
# L1: login yourbloo0 / yourbloo0
# L2: discover /s3cr3t/users.txt → login yourbloo1 + GATE_L2_ANSWER
# L3: Referer header from {SITE_URL}/terminal
# ----------------------------------------------------------------------------
GATE_L1_ANSWER=yourbloo0
GATE_L2_ANSWER=
GATE_TOKEN_SECRET=
# Optional; used by Next.js proxy.ts (X-Gate-Bypass), not validated in Rust gate handlers
GATE_BYPASS_SECRET=
GATE_COOKIE_MAX_AGE_DAYS=7
GATE_SESSION_TTL_HOURS=24

# ----------------------------------------------------------------------------
# OpenAPI / Swagger UI
# Set to false in production if you do not want /api/docs exposed.
# ----------------------------------------------------------------------------
ENABLE_SWAGGER_UI=true

# ----------------------------------------------------------------------------
# Phase 3A — Playground (live coding snippets)
# Admin: POST /api/playground/snippets · Public: GET /api/playground/snippets/{id}
# Max code payload: 64KB (enforced server-side).
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# Phase 3B — Newsletter (double opt-in via Resend)
# POST /api/newsletter/subscribe · GET /api/newsletter/confirm?token=
# POST /api/newsletter/unsubscribe · Admin broadcast under /api/admin/newsletter/*
# Confirm links use SITE_URL (or FRONTEND_ORIGIN) as the base URL.
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# Phase 3C — Headless CMS
# Set true to expose /api/v1/content/* (requires X-Api-Key header).
# Store SHA-256 hashes of keys in the `api_keys` table (scope: read | admin).
# ----------------------------------------------------------------------------
HEADLESS_CMS_ENABLED=false

# ----------------------------------------------------------------------------
# Phase 4A — AI assistant (Gemini SSE + RAG)
# POST /api/ai/chat streams tokens when GEMINI_API_KEY is set.
# pgvector extension is enabled when available; text search is the fallback.
# ----------------------------------------------------------------------------
GEMINI_API_KEY=

# ----------------------------------------------------------------------------
# Phase 4B — Visitor presence (WebSocket)
# GET /ws/presence — in-memory room counts; REDIS_URL reserved for scaling.
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# Metrics endpoint protection (optional but recommended in production)
# Set to require Authorization: Bearer <token> on GET /metrics
# ----------------------------------------------------------------------------
METRICS_BEARER_TOKEN=
