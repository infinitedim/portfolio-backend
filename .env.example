# =============================================================================
# Portfolio Backend — Environment Variables Example
# Copy this file to .env and fill in secrets before running.
# =============================================================================

# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8080
ENVIRONMENT=development

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
DATABASE_URL=postgres://portfolio:portfolio@localhost:5432/portfolio
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT=30
DB_CONNECT_RETRIES=5
DB_CONNECT_RETRY_SECS=2
DB_IDLE_TIMEOUT=600

# Test database (integration tests only)
# TEST_DATABASE_URL=postgres://portfolio:portfolio@localhost:5432/portfolio_test

# ----------------------------------------------------------------------------
# Auth (REQUIRED in production — fill with strong random values)
# ----------------------------------------------------------------------------
JWT_SECRET=
REFRESH_TOKEN_SECRET=
JWT_ISSUER=portfolio-backend
JWT_AUDIENCE=portfolio-frontend
TOTP_ISSUER=infinitedim.site

# ----------------------------------------------------------------------------
# Admin bootstrap (REQUIRED in production)
# ----------------------------------------------------------------------------
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Or use pre-hashed password instead of ADMIN_PASSWORD:
# ADMIN_HASH_PASSWORD=

# ----------------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000

# ----------------------------------------------------------------------------
# Email / Resend (optional)
# ----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM=
CONTACT_EMAIL=

# ----------------------------------------------------------------------------
# Roadmap.sh (optional)
# ----------------------------------------------------------------------------
ROADMAP_AUTH_TOKEN=

# ----------------------------------------------------------------------------
# RSS / Site metadata
# Should match frontend NEXT_PUBLIC_BASE_URL in production
# ----------------------------------------------------------------------------
SITE_URL=http://localhost:3000
SITE_TITLE=Dimas Saputra
SITE_DESCRIPTION=Full-Stack Developer Portfolio

# ----------------------------------------------------------------------------
# Uploads
# ----------------------------------------------------------------------------
UPLOAD_DIR=uploads

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_DIR=logs
RUST_LOG=info

# ----------------------------------------------------------------------------
# Swagger
# ----------------------------------------------------------------------------
ENABLE_SWAGGER_UI=true

# ----------------------------------------------------------------------------
# Gate (Terminal puzzle system)
# ----------------------------------------------------------------------------
# Level 1: Bandit 32→33 password (post-$0 escape)
GATE_L1_ANSWER=
# Level 2: Natas 33 flag / trigger token
GATE_L2_ANSWER=
# Level 3: Behemoth 7 password / payload token
GATE_L3_ANSWER=
# Optional precomputed md5 of level-2 stub file
GATE_L2_STUB_MD5=
# Behemoth 7 EIP offset (default 528)
GATE_L3_OFFSET=528
# Hex return address placeholder for payload validation
GATE_L3_RET_ADDR=e0d7ffff
# SHA256 hash of expected shellcode blob (hex)
GATE_L3_SHELLCODE_HASH=
# Secret for signing gate cookies (min 32 chars)
GATE_TOKEN_SECRET=
# Dev bypass secret — send X-Gate-Bypass header
GATE_BYPASS_SECRET=
# Unlock cookie max age in days
GATE_COOKIE_MAX_AGE_DAYS=7
# Progress session cookie TTL in hours
GATE_SESSION_TTL_HOURS=24
